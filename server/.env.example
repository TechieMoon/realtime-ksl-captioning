# Runtime model backend.
# - huggingface: real isolated-word KSL classifier from Hugging Face.
# - mock: connectivity-only test model that always returns a mock caption.
MODEL_BACKEND=huggingface

# Current production model repository. Keep this unless testing another model.
HF_MODEL_ID=Seoyoung07/korean-sign-word-classifier-mediapipe
HF_MODEL_REVISION=main

# Use auto for normal setup. It selects CUDA if available, otherwise CPU.
# Use cpu for maximum compatibility.
# Use cuda only when PyTorch CUDA is installed and torch.cuda.is_available() is true.
MODEL_DEVICE=auto

MODEL_TOP_K=5
SEQUENCE_TARGET_FPS=15
FRAME_QUEUE_SIZE=2
MAX_SEGMENT_FRAMES=180

# Optional. Set only when using a private Hugging Face model.
# A read token is enough for inference. Do not commit real tokens.
# HF_TOKEN=

# Optional. If set, frontend must pass the same token query parameter.
# CAPTION_AUTH_TOKEN=
